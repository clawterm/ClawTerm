{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawTerm",
  "version": "1.6.4",
  "identifier": "com.clawterm.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A Mac-native terminal workspace for running many AI agents at once.",
    "longDescription": "ClawTerm is a Mac-native terminal built for focused technical workflows. Vertical tab sidebar, live agent status, split panes, per-pane context tracking, and desktop notifications — designed around running many AI coding agents at once without losing track of them.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist",
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/clawterm/clawterm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwQjk5OTQ1NzA2QTI2Q0EKUldUS0ptcHdSWm01VUpIY2tFdUlHNW5xSTdwMlYweDFnOE4yaDRvTWFiSG9iMEU2Q0k0bHdDRGoK"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ClawTerm",
        "width": 1100,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'"
    }
  }
}
